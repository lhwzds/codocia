#!/usr/bin/env node

const { spawn } = require("child_process");
const path = require("path");

const binaryName = process.platform === "win32" ? "codocia-bin.exe" : "codocia-bin";
const binaryPath = path.join(__dirname, binaryName);

const child = spawn(binaryPath, process.argv.slice(2), {
  stdio: "inherit",
});

child.on("error", (error) => {
  console.error(`Failed to run codocia: ${error.message}`);
  console.error("Try reinstalling the package, or install Rust and run: cargo install codocia");
  process.exit(1);
});

child.on("exit", (code, signal) => {
  if (signal) {
    process.kill(process.pid, signal);
    return;
  }
  process.exit(code || 0);
});
